{
  "name": "quran-quick-insert",
  "title": "Quran Quick Insert",
  "description": "Search, copy, and insert Quran ayahs or ranges.",
  "icon": "icon.png",
  "author": "yshalsager",
  "license": "MIT",
  "packageManager": "npm@11.13.0",
  "engines": {
    "node": ">=22.22.2"
  },
  "platforms": [
    "macOS"
  ],
  "categories": [
    "Productivity"
  ],
  "keywords": [
    "quran",
    "ayah",
    "islam",
    "arabic",
    "verse",
    "copy",
    "paste"
  ],
  "commands": [
    {
      "name": "search-quran",
      "title": "Search Quran",
      "description": "Search Quran text or enter an ayah range to copy or paste.",
      "mode": "view"
    }
  ],
  "preferences": [
    {
      "name": "text_style",
      "title": "Text Style",
      "description": "Quran text style used for copied output.",
      "type": "dropdown",
      "required": false,
      "default": "uthmani",
      "data": [
        {
          "title": "Uthmani",
          "value": "uthmani"
        },
        {
          "title": "Imlai",
          "value": "imlai"
        }
      ]
    },
    {
      "name": "reference_style",
      "title": "Reference Style",
      "description": "How ayah references are added to copied output.",
      "type": "dropdown",
      "required": false,
      "default": "arabic",
      "data": [
        {
          "title": "[البقرة: 255]",
          "value": "arabic"
        },
        {
          "title": "(2:255)",
          "value": "paren"
        },
        {
          "title": "Quran 2:255",
          "value": "quran"
        },
        {
          "title": "None",
          "value": "none"
        }
      ]
    },
    {
      "name": "prefix",
      "title": "Text Prefix",
      "description": "Optional text before copied ayahs.",
      "type": "dropdown",
      "required": false,
      "default": "none",
      "data": [
        {
          "title": "None",
          "value": "none"
        },
        {
          "title": "قال تعالى",
          "value": "qaal"
        },
        {
          "title": "الاستعاذة",
          "value": "istiadhah"
        },
        {
          "title": "البسملة",
          "value": "basmalah"
        }
      ]
    },
    {
      "name": "simplify_words",
      "title": "Simplify Search Letters",
      "label": "Simplify Search Letters",
      "description": "Match common Arabic letter variants while searching, like ا/أ/إ/آ and و/ؤ.",
      "type": "checkbox",
      "required": false,
      "default": true
    },
    {
      "name": "use_regex",
      "title": "Regex Search",
      "label": "Regex Search",
      "description": "Treat search input as a regular expression.",
      "type": "checkbox",
      "required": false,
      "default": false
    },
    {
      "name": "harakat",
      "title": "Search Harakat",
      "description": "How search handles Arabic diacritics.",
      "type": "dropdown",
      "required": false,
      "default": "ignore",
      "data": [
        {
          "title": "Ignore Harakat",
          "value": "ignore"
        },
        {
          "title": "Existing Only",
          "value": "existing_only"
        },
        {
          "title": "Exact",
          "value": "exact"
        }
      ]
    }
  ],
  "scripts": {
    "build": "ray build -e dist",
    "check": "tsc --outDir .check && node .check/src/quran-check.js",
    "dev": "ray develop",
    "lint": "ray lint"
  },
  "dependencies": {
    "@raycast/api": "^1.104.19",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.1",
    "eslint": "^9.39.1",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.17",
    "typescript": "^5.7.2"
  }
}
